<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- MASVS-STORAGE / MASVS-PRIVACY: exclude local database, session
             preferences, and app files from Android 12+ cloud backup. -->
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="file" path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Also exclude sensitive local data from device-to-device transfer. -->
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="file" path="." />
    </device-transfer>
</data-extraction-rules>
