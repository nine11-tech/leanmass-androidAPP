<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- MASVS-STORAGE / MASVS-PRIVACY:
         The app stores account/session and health-related calculation data locally.
         Even with android:allowBackup="false", these exclusions document and enforce
         that SQLite databases and SharedPreferences are not included in Auto Backup. -->
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="file" path="." />
</full-backup-content>
